# Backend
SESSION_TTL_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rupeeradar

# Groq LLM (Phase 5+)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ENABLE_LLM=false
LLM_RPM_LIMIT=30
LLM_TPM_LIMIT=1000
LLM_RPD_LIMIT=12000
LLM_TPD_LIMIT=100000

# Frontend (Vite — prefix with VITE_)
VITE_API_URL=http://localhost:8000
